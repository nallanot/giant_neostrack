# =========================================================
# Images
# =========================================================
POSTGIS_IMAGE=postgis/postgis:16-3.4
REDIS_IMAGE=redis:8.0
FITTRACKEE_IMAGE=fittrackee/fittrackee:v1.3.2
NEOSTRACK_IMAGE=python:3.12-slim

# =========================================================
# PostgreSQL
# =========================================================
POSTGRES_DB=fittrackee
POSTGRES_USER=fittrackee
POSTGRES_PASSWORD=change_me_strong

# =========================================================
# FitTrackee
# =========================================================
FITTRACKEE_HOST=fittrackee.tondomaine
FITTRACKEE_PUBLIC_URL=https://fittrackee.tondomaine

FITTRACKEE_APP_SECRET_KEY=change_me_secret_key_long_random_2026
FITTRACKEE_SECURITY_PASSWORD_SALT=change_me_password_salt_2026

FITTRACKEE_TASKS_TIME_LIMIT=3600
FITTRACKEE_WORKER_PROCESSES=2

# =========================================================
# Compte FitTrackee utilisé par l'API NeoStrack
# =========================================================
FITTRACKEE_EMAIL=ton_email
FITTRACKEE_USERNAME=ton_username
FITTRACKEE_PASSWORD=ton_password
FITTRACKEE_SPORT_ID=1

# =========================================================
# Cartes OpenStreetMap
# =========================================================
TILE_SERVER_URL=https://{s}.tile.openstreetmap.fr/osmfr/{z}/{x}/{y}.png
STATICMAP_SUBDOMAINS=a,b,c
MAP_ATTRIBUTION='fond de carte par <a href="http://www.openstreetmap.fr/mentions-legales/" target="_blank" rel="nofollow noopener">OpenStreetMap France</a>, sous <a href="http://creativecommons.org/licenses/by-sa/2.0/fr/" target="_blank" rel="nofollow noopener">licence CC BY-SA</a>'

# =========================================================
# NeoStrack API
# =========================================================
NEOSTRACK_HOST=upload.neostrack.com
NEOSTRACK_ENTRYPOINT=web
NEOSTRACK_ROUTER_PRIORITY=99999

# =========================================================
# Traefik
# =========================================================
TRAEFIK_NETWORK=traefik_default
TRAEFIK_HTTPS_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=tonresolver

# =========================================================
# NFS
# =========================================================
NFS_HOST=tonip
NFS_ROOT=/nfs/docker
NFS_OPTIONS=addr=tonip,nfsvers=4,soft,rw
